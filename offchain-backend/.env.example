# Custom deployment values
DATABASE_URL=postgres://user:password@host:5432/database
APP_ENV=production
ENABLE_PHASE2_REVIEWER_ROUTES=0
ENABLE_TELEGRAM_ROUTES=0

# Default LLM path: OpenRouter
OPENROUTER_API_KEY=replace-me

# Public payment endpoint config
PUBLIC_API_BASE_URL=https://your-domain.example
X402_RECIPIENT_ADDRESS=replace-with-your-solana-recipient
PAYAI_API_KEY_ID=replace-with-payai-api-key-id
PAYAI_API_KEY_SECRET=payai_sk_replace-with-payai-api-key-secret

# Telegram deployment
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_URL=https://your-domain.example/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-me

# Defaults below are safe to keep unless you need to override behavior
HOST=0.0.0.0
PORT=3000

LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
LLM_PROMPT_TEMPLATE_VERSION=reviewer-offchain-prompt-v1
LLM_MODEL_ID=openrouter/auto
LLM_PROCESSING_VERSION=offchain-llm-pipeline-v1

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=gemini-pm

TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org

# x402 payment verification
X402_VERSION=2
X402_SCHEME=exact
X402_PRICE_USD=1.00
X402_MAX_AMOUNT_REQUIRED=1000000
X402_ASSET_SYMBOL=USDC
X402_NETWORK=solana:devnet
X402_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
X402_MAX_TIMEOUT_SECONDS=300
X402_FACILITATOR_URL=https://facilitator.payai.network

# Legacy migration fallback. Prefer PAYAI_API_KEY_ID/PAYAI_API_KEY_SECRET above.
X402_FACILITATOR_AUTH_TOKEN=

# Optional alternate LLM provider settings
# Use these only if LLM_PROVIDER is changed from the default "openrouter".
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

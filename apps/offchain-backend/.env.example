# Required deployer edits for a real deployment
# Current reviewer auth is still a single shared token.
# Reviewer panel auth by Solana address is not implemented yet.
REVIEWER_AUTH_TOKEN=replace-me

# Default real LLM path: OpenRouter
OPENROUTER_API_KEY=replace-me

# Telegram bot deployment
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_URL=https://your-domain.example/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-me

# Defaults below are safe to keep unless you need to override behavior
HOST=0.0.0.0
PORT=3000

LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
LLM_PROMPT_TEMPLATE_VERSION=reviewer-offchain-prompt-v1
LLM_MODEL_ID=openrouter/auto
LLM_PROCESSING_VERSION=offchain-llm-pipeline-v1

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_NAME=gemini-pm

TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org

MARKET_CACHE_PATH=./data/market-cache.json
UPCOMING_MARKET_CACHE_PATH=./data/upcoming-market-cache.json
CLARIFICATION_REQUESTS_PATH=./data/clarification-requests.json
VERIFIED_PAYMENTS_PATH=./data/verified-payments.json
BACKGROUND_JOBS_PATH=./data/background-jobs.json
ARTIFACTS_PATH=./data/artifacts.json
REVIEWER_SCANS_PATH=./data/reviewer-scans.json
UPCOMING_REVIEWER_SCANS_PATH=./data/upcoming-reviewer-scans.json

# x402 payment verification
PUBLIC_API_BASE_URL=https://your-domain.example
X402_VERSION=2
X402_SCHEME=exact
X402_PRICE_USD=1.00
X402_MAX_AMOUNT_REQUIRED=1000000
X402_ASSET_SYMBOL=USDC
X402_NETWORK=solana:devnet
X402_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
X402_RECIPIENT_ADDRESS=replace-with-your-solana-recipient
X402_MAX_TIMEOUT_SECONDS=300
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_FACILITATOR_AUTH_TOKEN=replace-with-cdp-bearer-token

# Optional alternate LLM provider settings
# Use these only if LLM_PROVIDER is changed from the default "openrouter".
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
